# ============================================================================
# Chatbot Core — Example Environment Variables
# ============================================================================
# Copy this file to `.env` and replace placeholder values.
# `ADMIN_API_KEY` is a server-side secret for protected admin/management
# endpoints. Do not share it with end users or tenants.
# ============================================================================

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://shared:shared_secret@127.0.0.1:5433/chatbot
DB_ECHO=false

# ── LLM — OpenRouter / LiteLlm ────────────────────────────────────────────
OPENROUTER_API_KEY=<OPENROUTER_API_KEY>
NVIDIA_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_THINKING=disabled
MODEL_NAME=nvidia_nim/google/gemma-4-31b-it
MODEL_DISPLAY=gemma-4-31b-it
FALLBACK_MODEL_1=openrouter/nvidia/nemotron-3-super-120b-a12b:free
FALLBACK_MODEL_2=groq/llama3-8b-8192

# ── Session backend / Redis ────────────────────────────────────────────────
SESSION_BACKEND=redis
REDIS_URL=redis://localhost:6379/0
REDIS_NAMESPACE=chatbot:adk:v1
REDIS_SESSION_TTL_SECONDS=86400
REDIS_LOCK_TIMEOUT_SECONDS=15
REDIS_LOCK_BLOCKING_TIMEOUT_SECONDS=5.0
REDIS_HEALTH_CHECK_INTERVAL=30
REDIS_SOCKET_TIMEOUT_SECONDS=5.0
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=5.0
REDIS_MAX_CONNECTIONS=100
REDIS_RETRY_ATTEMPTS=3

# ── Business configuration defaults ────────────────────────────────────────
BUSINESS_NAME=Mi Negocio
BUSINESS_EMAIL=contacto@minegocio.com
BUSINESS_PHONE=+56912345678
BUSINESS_ADDRESS=Calle Principal 123
BUSINESS_CITY=Santiago
BUSINESS_WEBSITE=
BUSINESS_HOURS=

# ── Security & Channels ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<TELEGRAM_BOT_TOKEN>
ADMIN_API_KEY=<ADMIN_API_KEY_LARGA_Y_PRIVADA>
ALLOWED_ORIGINS=http://localhost:8083

# ── Application ────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
